fn test(int i) -> int {
    if (i == 0)
        return 0;
    else if (i == 1) {
        return 1;
    }
    else if (i == 2) {
        mut int j = i + 1;
        j *= i;
        return j;
    }
    else {
        mut int sum;
        for (int j in 0..=i**2) {
            sum += j;
        }
        return sum;
    }
}

fn inString(String str, char chr) -> bool {
    for (char c in str) {
        if (c == chr)
            return true;
    }
    return false;
}

fn getFirstIndexOfCharInString(String str, char chr) -> int {
    for (int i, char c in str[..]) {
        if (c == chr)
            return i;
    }
    return -1;
}

fn main() -> int {
