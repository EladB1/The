        val *= 2;
    }
    int x = 50;
    mut int64 total = 0;
    
    for (mut int i = 0; i <= x / 2 || i > 1000; i++) { // FIX
        total += i;
    }
    for (total = 0; i < x; i++) {
        for (int j = i; j < x; j++) {
            println(j - i);
        }
    }
    while(true) {
        break;
    }
    for (int ii in 0 ..= 16 .. 2) {
        println(ii);
    }
    return 0;
}