struct Empty {}

interface Device {
    fn powerOn() -> bool;
    fn powerOff();
    fn restart() -> bool {
        powerOff();
        return powerOn();
    }
    fn uptimeHours() -> uint32 {
        return 0;
    }
}

struct Server impl Device {
    private {
        // not real implementations of time... obviously
        mut uint32 lastStartTime;
        mut uint32 now;
    }
    Device {
        fn powerOn() -> bool {
            lastStartTime = now;
            println("Powering on...");
            sleep(2.0); // TODO: remove need for casting
            return true;
        }
        fn powerOff() {
            println("powering off...");
        }
        fn uptimeHours() -> uint32 {
            return now - lastStartTime;
        }
    }
}

interface App {
    fn help() -> String;
}

interface Compiler {
    fn help() -> String {
        return "./compiler [source_file]";
    }
}

struct CompilerApp impl App, Compiler {
    // implementation conflict: both have `help` function
    Compiler {}
    App {
        fn help() -> String {
            return "./compiler-app [source_file] [OPTIONS]";
        } 
    }
}

fn resolveImplementationConflict() { // Disambiguation
    CompilerApp ca = CompilerApp{};
    println(ca.Compiler.help());
    println(ca.App.help());
}

struct EmploymentStatus {
    mut bool employed;
}

struct Person {
    String first;
    String last;
    uint32 age;
    private String ssn;
    EmploymentStatus status;
}

fn main() -> int {
    Person p1 = Person {
        first: "name",
        last: "othername",
        age: 25,
        ssn: "000000000",
        status: EmploymentStatus {employed: true},
    };
    Person p2 = Person {
        first: "name",
        last: "othername",
        age: 12,
        status: EmploymentStatus {employed: false},
        ssn: "000000001"
    };
    String personString = p1 as String;
    p1 == p2;
    p1.first == p2.first;
    if (p1.status.employed && p2.status.employed)
        println("woot");
    return 0;
}