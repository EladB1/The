struct PostgreSQL impl DB {
    DB {
        fn connect() {
            println("Connected to DB server");
        }
        fn connect(bool TLS) {
            if (TLS) {
                println("Connected to DB server with TLS");
            } else {
                printerr("Warning: insecure connection");
                println("Connected to DB server");
            }
        }
        fn connect() -> bool {
            return true;
        }
    }
}

