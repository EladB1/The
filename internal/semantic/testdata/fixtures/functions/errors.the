fn missingReturnNestedIfBlocks(int i, int j) -> bool {
    if (i < j) {
        if (i % 2 == 0) {
            return i / 2;
        }
        // missing return for the above if statement condition being false
    } else {
        if (j % 2 == 0) {
            return j / 2;
        }
        else if (j % 3 == 0) {
            return j / 3;
        }
        else
            return j;
    }
}

