struct Object {
    int i;
    private {
        uint64 j;
    }
    cast {
        fn toInt() -> int {
            return i+j;
        }
    }
    compare {
        fn lessThan(Object other) -> bool {
            return i < other.i && j < other.j;
        }
    }
}

