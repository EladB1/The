interface A {
    fn test() -> int;
}

interface B {
    fn do(int i) -> bool;
}

struct C impl A, B {
    A {}
}

struct D impl A,A {
    A {}
}

struct E impl A, B {
    A {
        fn test();
        fn extra() -> int;
    }
    B {
        fn do() -> bool;
        fn extra();
    }
}
interface F {
    fn something() {
        println("something");
        E e = E{};
        e.extra();
    }
}