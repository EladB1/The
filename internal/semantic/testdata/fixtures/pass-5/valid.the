struct A {}
interface B {
    fn test();
    fn implemented() -> bool {
        return true;
    }
}
struct C impl B {
    B {
        fn test() {
            return;
        }
    }
}
interface D {
    fn action(C c1, C c2) -> bool;
    fn action(C c) -> bool;
}
struct E impl B,D {
    B {
        fn test() {
            println("in E");
        }
        fn implemented() -> bool {
            return true && false;
        }
    }
    D {
        fn action(C c1, C c2) -> bool {
            return c1.implemented() && c2.implemented();
        }
        fn action(C c1) -> bool {
            return !c1.implemented;
        }
    }
}