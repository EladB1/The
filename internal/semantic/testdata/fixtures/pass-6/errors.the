interface A {
    fn test();
    fn test2() -> int;
}

interface B {
    fn test();
    fn test2(int i) -> String; 
}

struct C impl A, B {
    A {
        fn test() {
            return;
        }
        fn test2() -> int {
            return 0;
        }
    }
    B {
        fn test() {
            println("hello");
        }
        fn test2(int i) -> String {
            return 1;
        }
    }
}

C instance = C{};
int j = instance.test();
int i = instance.test2();
int n = instance.Q.test();

struct D {
    fn test() -> int {
        return sum() + product();
    }
    int i;
    private {
        int j;
        fn sum() -> int {
            return i+j+k;
        }
    }
    private {
        int k;
        fn product() -> int {
            return i * j * k;
        }
    }
}
