// Primitive types

int i = 0;
double y = 0;
double y2 = y + 1;
int x = i + 1;
double z = y * x;
float f = -1.2;
char third = "something"[2];
int negate = ~0;
int minus = -negate;
uint32 u1 = 0xff;
uint64 u2 = 0xffff;
uint64 u3 = u1 + u2;
int64 i64 = 2000 + i;
bool is = (false || true) && !false;
int len = "hello".length;
String greet = "hello, world!";
String copy = greet[..];
String slice1 = greet[..5];
String slice2 = greet[5..];
String end = greet[^1];
String slice3 = greet[^3 ..= ^1];
float expo = 2 ** 32;
// functions

fn plusOne(int i) -> int {
    return i + 1;
}

int x2 = plusOne(x);

// structs/interfaces
Object o = Object {i: 0, j: 1024};
Object o2 = Object{i: -1, j: 1023};
struct Object {
    int i;
    private {
        int j;
    }
    cast {
        fn toInt() -> int {
            return i+j;
        }
    }
    compare {
        fn lessThan(Object other) -> bool {
            return i < other.i && j < other.j;
        }
    }
    fn test(int x, int y) -> int {
        return i + j + x + y;
    }
}
bool less = o2 < o;
int oint = o as int;
int oi = o.i;
struct Thing {
    uint32 value;
}
Thing t1 = Thing {
    value: 32,
};
Thing t2 = Thing{};
bool equal = t1 == t2;

struct Nested {
    Object object;
}

Nested nested = Nested {
    object: o,
};
int nestedValue = nested.object.i;
int val = o.test(10, 20);
int nestedVal = nested.object.test(30, 40);

interface A {
    fn test() -> String;
}

interface B {
    fn test2(int i) -> int;
}

struct C impl A, B {
    A {
        fn test() -> String {
            return "test";
        }
    }
    B {
        fn test2(int i) -> int {
            return i * 2;
        }
    }
}
C newC = C{};
String Ctest = newC.test();
int Ctest2 = newC.test2(7);