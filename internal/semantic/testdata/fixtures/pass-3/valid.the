    D {
        fn sample() {
            return;
        }
    }
}

struct F {
    int x;
    int y;
    private {
        int z;
        fn action() {
            println(z);
        }
    }
    cast {
        fn toString() -> String {
            return (x as String) + ", " + (y as String);
        }
        
    }
    compare {
        fn equals(F other) -> bool {
            return x == other.x && y == other.y;
        }
        fn lessThan(F other) -> bool {
            return x < other.x || y < other.y;
        }
        fn greaterThan(F other) -> bool {
            return x > other.x || y > other.y;
        }
    }
}